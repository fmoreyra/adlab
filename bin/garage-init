#!/usr/bin/env bash

# One-time Garage initialization script.
# Run this after the garage container is started for the first time.
# It assigns the layout, creates the bucket, and generates an API key.
#
# Usage:
#   bin/garage-init
#
# Prerequisites:
#   - The garage container must be running:
#       docker compose --profile garage up -d garage
#   - An rpc_secret must be set in etc/garage.toml
#     (generate one with: openssl rand -hex 32)

set -euo pipefail

COMPOSE_FILES="${COMPOSE_FILES:--f compose.yaml}"
BUCKET_NAME="${AWS_STORAGE_BUCKET_NAME:-adlab-media}"
KEY_NAME="${GARAGE_KEY_NAME:-adlab-app-key}"

garage_exec() {
  docker compose "${COMPOSE_FILES}" exec -T garage /garage "$@"
}

echo "=== Garage Initialization ==="
echo

# 1. Check Garage is running
echo "1. Checking Garage status..."
if ! garage_exec status >/dev/null 2>&1; then
  echo "ERROR: Garage container is not running or not healthy."
  echo "Start it first: docker compose --profile garage up -d garage"
  exit 1
fi
echo "   Garage is running."
echo

# 2. Get node ID and assign layout
echo "2. Assigning storage layout..."
NODE_ID=$(garage_exec status 2>/dev/null | grep -oE '[0-9a-f]{16}' | head -1)
if [[ -z "$NODE_ID" ]]; then
  echo "ERROR: Could not determine Garage node ID."
  exit 1
fi
echo "   Node ID: ${NODE_ID}"

garage_exec layout assign -z dc1 -c 1G "${NODE_ID}" 2>/dev/null || true
echo "   Layout assigned."

# 3. Apply layout
echo "3. Applying layout..."
LAYOUT_VERSION=$(garage_exec layout show 2>/dev/null | grep -oP 'apply --version \K[0-9]+' || echo "")
if [[ -n "$LAYOUT_VERSION" ]]; then
  garage_exec layout apply --version "${LAYOUT_VERSION}" 2>/dev/null
  echo "   Layout applied (version ${LAYOUT_VERSION})."
else
  echo "   Layout already applied or no changes pending."
fi
echo

# 4. Create bucket
echo "4. Creating bucket '${BUCKET_NAME}'..."
if garage_exec bucket info "${BUCKET_NAME}" >/dev/null 2>&1; then
  echo "   Bucket '${BUCKET_NAME}' already exists."
else
  garage_exec bucket create "${BUCKET_NAME}"
  echo "   Bucket '${BUCKET_NAME}' created."
fi
echo

# 5. Create API key
echo "5. Creating API key '${KEY_NAME}'..."
KEY_OUTPUT=$(garage_exec key info "${KEY_NAME}" 2>/dev/null || true)
if echo "${KEY_OUTPUT}" | grep -q "Key ID:"; then
  echo "   Key '${KEY_NAME}' already exists."
  KEY_ID=$(echo "${KEY_OUTPUT}" | grep "Key ID:" | awk '{print $NF}')
  KEY_SECRET=$(echo "${KEY_OUTPUT}" | grep "Secret key:" | awk '{print $NF}')
else
  KEY_OUTPUT=$(garage_exec key create "${KEY_NAME}" 2>/dev/null)
  KEY_ID=$(echo "${KEY_OUTPUT}" | grep "Key ID:" | awk '{print $NF}')
  KEY_SECRET=$(echo "${KEY_OUTPUT}" | grep "Secret key:" | awk '{print $NF}')
  echo "   Key '${KEY_NAME}' created."
fi
echo

# 6. Grant key access to bucket
echo "6. Granting key access to bucket..."
garage_exec bucket allow --read --write --owner "${BUCKET_NAME}" --key "${KEY_NAME}" 2>/dev/null || true
echo "   Key '${KEY_NAME}' granted read/write/owner on '${BUCKET_NAME}'."
echo

# 7. Print summary
echo "=== Garage Initialization Complete ==="
echo
echo "Add these values to your .env file:"
echo
echo "  export USE_S3_STORAGE=true"
echo "  export AWS_S3_ENDPOINT_URL=http://garage:3900"
echo "  export AWS_S3_REGION_NAME=garage"
echo "  export AWS_S3_ADDRESSING_STYLE=path"
echo "  export AWS_STORAGE_BUCKET_NAME=${BUCKET_NAME}"
echo "  export AWS_ACCESS_KEY_ID=${KEY_ID}"
echo "  export AWS_SECRET_ACCESS_KEY=${KEY_SECRET}"
echo
echo "Then restart your web/worker containers to pick up the changes."
